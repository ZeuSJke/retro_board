# ──────────────────────────────────────────────────────────────────────────────
# RetroBoard — Environment Variables
# Скопируй этот файл в .env и заполни значения
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_DB=retroboard
POSTGRES_USER=retro
# ! Смени пароль перед деплоем на продакшн !
POSTGRES_PASSWORD=change_me_in_production

# ── Backend ────────────────────────────────────────────────────────────────────
# Разрешённые CORS-источники (через запятую, без пробелов)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
