# ──────────────────────────────────────────────────────────────────────────────
# RetroBoard — Backend Environment Variables
# Для локальной разработки без Docker
#
# Скопируй этот файл:  cp .env.example .env
# Затем заполни значения под своё окружение
# ──────────────────────────────────────────────────────────────────────────────

# ── База данных ───────────────────────────────────────────────────────────────
# Строка подключения к PostgreSQL
# Формат: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://retro:retro@localhost:5432/retroboard

# ── CORS ──────────────────────────────────────────────────────────────────────
# Адреса фронтенда, которым разрешены запросы к API
# Несколько значений — через запятую, без пробелов
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
